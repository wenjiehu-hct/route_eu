{
  "name": "global-road-test-studio",
  "version": "1.0.0",
  "type": "module",
  "description": "Global Road Test Studio - 海外法规道路测试与路线规划平台",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "test": "npm run lint && npm run test:stores && npm run test:smoke",
    "test:stores": "node scripts/store-regression.mjs",
    "preview": "vite preview",
    "test:smoke": "electron scripts/react-smoke.cjs",
    "test:smoke:dist": "cross-env SMOKE_DIST=1 electron scripts/react-smoke.cjs",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "vite build && electron-builder --win",
    "electron:build:mac": "vite build && electron-builder --mac",
    "electron:build:linux": "vite build && electron-builder --linux"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^10.0.3",
    "cross-env": "^7.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "vite": "^6.2.0",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.routeplanner.pro",
    "productName": "Global Road Test Studio",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "electron/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "electron/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "electron/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Global Road Test Studio"
    }
  }
}
